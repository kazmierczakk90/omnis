{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User preferences and system metrics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "KnowledgeItem": {
      "title": "Knowledge Item",
      "description": "A single piece of information acquired by the agent",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string" },
        "importance": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User record"
    },
    "/users/{userId}/knowledge": {
      "schema": "KnowledgeItem",
      "description": "Acquired knowledge for the user"
    }
  }
}
